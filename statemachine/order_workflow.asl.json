{
  "comment": "Order Processing Workflow",
  "StartAt": "FetchSalseforceData",
  "States": {
    "FetchSalseforceData":{
      "Type": "Task",
      "Resource": "${FetchLambdaArn}",
      "Retry": [
        {
          "ErrorEquals": ["States.TaskFailed"],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackOffRate": 2.0
        }
      ],
      "Catch":[
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "MarkAsFailed"
        }
      ],
      "Next": "ProcessAndStoreOrder"
    },
    "ProcessAndStoreOrder": {
      "Type": "Task",
      "Resource": "${ProcessLambdaArn}",
      "End": true
    },
    "MarkAsFailed": {
      "Type": "Fail",
      "Cause": "Failed to fetch or process order"
    }
  }
}